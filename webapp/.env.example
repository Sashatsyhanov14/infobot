# --- Настройки базы данных Supabase (ОБЯЗАТЕЛЬНО) ---
# Возьми их в настройках твоего проекта Supabase -> Project Settings -> API
SUPABASE_URL=твоя_ссылка
SUPABASE_ANON_KEY=твой_ключ

# --- Секретные ключи для Vercel Serverless (если понадобятся для /api) ---
BOT_TOKEN=твой_токен_телеграм
OPENAI_API_KEY=твой_ключ_от_polza_ai

# Настройки проекта (Брендирование)
APP_TITLE="Tour Gude Bot"
BOT_USERNAME="your_bot_username"
NICHE_TYPE="tourism" # tourism, medical, consulting, translation
WELCOME_MESSAGE="Привет! Я твой ассистент..."
WEBAPP_BUTTON_TEXT="🎒 Открыть Каталог"

# Роль AI (Промпты)
SYSTEM_ROLE_NAME="Главный гид"
SYSTEM_NICHE_DESCRIPTION="туризма и экскурсий"

# Данные Telegram
BOT_TOKEN=your_telegram_bot_token

# Данные OpenAI / OpenRouter
OPENAI_API_KEY=your_openrouter_api_key

# Данные Supabase (Серверные)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Настройки WebApp
WEBAPP_URL=https://bot2.yourdomain.com

# Настройка порта (для PM2)
PORT=3002
